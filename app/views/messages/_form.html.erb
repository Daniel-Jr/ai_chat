<%= form_with url: chat_messages_path(chat),
      data: {
        controller: "message-form",
        action: "turbo:submit-start->message-form#onSubmitStart turbo:submit-end->message-form#onSubmitEnd"
      },
      class: "flex items-end gap-3" do |f| %>

  <div class="relative flex-1" data-controller="autogrow">
    <%= f.text_area :content,
          rows: 1,
          placeholder: "Ask anything...",
          class: "w-full resize-none overflow-hidden rounded-2xl border border-neutral-200 bg-neutral-50 px-4 py-3 pr-12 text-sm text-neutral-900 shadow-xs outline-none transition-colors placeholder:text-neutral-400 focus:border-neutral-400 focus:bg-white focus:ring-0 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-900 dark:placeholder-neutral-500 dark:focus:border-neutral-500",
          data: {
            autogrow_target: "input",
            action: "keydown->message-form#submitOnEnter input->autogrow#resize"
          },
          maxlength: 8000 %>
  </div>

  <%= f.button type: "submit",
        class: "flex size-10 shrink-0 items-center justify-center rounded-full bg-neutral-800 text-white shadow-xs transition-colors hover:bg-neutral-700 active:bg-neutral-900 disabled:opacity-50 dark:bg-neutral-200 dark:text-neutral-900 dark:hover:bg-neutral-300",
        data: { message_form_target: "submit" } do %>
    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
    </svg>
  <% end %>
<% end %>
