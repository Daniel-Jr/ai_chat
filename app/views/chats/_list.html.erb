<% if chats.any? %>
  <p class="mb-1 px-2 text-xs font-medium text-neutral-400 uppercase tracking-wide dark:text-neutral-500">Recent chats</p>
  <ul class="space-y-0.5">
    <% chats.each do |chat| %>
      <li>
        <%= link_to chat_path(chat),
              class: "flex items-center gap-2 rounded-lg px-2 py-2 text-sm transition-colors #{active_chat_id.to_i == chat.id ? 'bg-neutral-200 text-neutral-900 font-medium dark:bg-neutral-700 dark:text-white' : 'text-neutral-600 hover:bg-neutral-100 hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-200'}" do %>
          <svg class="size-4 shrink-0 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
          </svg>
          <span class="truncate"><%= chat.title %></span>
        <% end %>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="px-2 py-4 text-center text-xs text-neutral-400 dark:text-neutral-500">No chats yet</p>
<% end %>
