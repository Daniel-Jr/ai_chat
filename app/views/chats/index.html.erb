<div class="flex h-screen overflow-hidden">
  <%= render "shared/sidebar", chats: @chats, active_chat: nil %>

  <!-- Main content: empty state (shown only when user has no chats) -->
  <main class="flex flex-1 flex-col overflow-hidden bg-white dark:bg-neutral-900">
    <div class="flex flex-1 flex-col items-center justify-center gap-6 p-8 text-center">
      <div class="flex size-16 items-center justify-center rounded-2xl bg-neutral-100 dark:bg-neutral-800">
        <svg class="size-8 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
        </svg>
      </div>
      <div>
        <h2 class="text-xl font-semibold text-neutral-800 dark:text-neutral-200">No chats yet</h2>
        <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">Start a new conversation with the AI.</p>
      </div>
      <%= render "shared/new_chat_button" %>
    </div>
  </main>
</div>
