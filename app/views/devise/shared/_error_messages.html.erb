<% if resource.errors.any? %>
  <div class="mb-4 rounded-lg border border-red-200 bg-red-50 p-3 dark:border-red-800 dark:bg-red-900/20">
    <p class="text-xs font-semibold text-red-700 dark:text-red-400 mb-1">
      <%= pluralize(resource.errors.count, "error") %> prevented this action:
    </p>
    <ul class="list-disc list-inside space-y-0.5">
      <% resource.errors.full_messages.each do |message| %>
        <li class="text-xs text-red-600 dark:text-red-400"><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
